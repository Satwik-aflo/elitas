---
// The home-hero sun: the Bioma dome on its horizon line, with a wheel of fine
// hairline rays in slow rotation (picked from prototype variant B, 2 Jul 2026).
const CX = 600;
const CY = 170;
const RAY_COUNT = 36;
const RAY_INNER = 104;
const rays = Array.from({ length: RAY_COUNT }, (_, i) => {
  const angle = (i * 360) / RAY_COUNT;
  const outer = i % 3 === 0 ? 156 : i % 3 === 1 ? 134 : 120;
  const rad = (angle * Math.PI) / 180;
  return {
    x1: CX + RAY_INNER * Math.cos(rad),
    y1: CY + RAY_INNER * Math.sin(rad),
    x2: CX + outer * Math.cos(rad),
    y2: CY + outer * Math.sin(rad),
  };
});
---

<svg viewBox="0 0 1200 180" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
  <defs>
    <clipPath id="sun-horizon-clip"><rect x="0" y="0" width="1200" height="170"></rect></clipPath>
  </defs>
  <g clip-path="url(#sun-horizon-clip)">
    <g class="sun-rays">
      {
        rays.map((r) => (
          <line
            x1={r.x1}
            y1={r.y1}
            x2={r.x2}
            y2={r.y2}
            stroke="var(--laterite)"
            stroke-width="1.6"
            opacity="0.75"
          />
        ))
      }
    </g>
    <path d="M520 170 A80 80 0 0 1 680 170 Z" fill="var(--laterite)"></path>
  </g>
  <line x1="0" y1="170" x2="1200" y2="170" stroke="var(--ink)" stroke-width="2.5"></line>
</svg>

<style>
  svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .sun-rays {
    animation: sun-spin 80s linear infinite;
    transform-origin: 600px 170px;
  }

  @keyframes sun-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sun-rays {
      animation: none;
    }
  }
</style>
