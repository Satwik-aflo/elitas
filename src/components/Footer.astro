---
import ElitasMark from './ElitasMark.astro';
import { SITE, whatsappHref, withBase } from '../lib/site';

const year = new Date().getFullYear();
---

<footer class="footer" id="contact">
  <div class="container">
    <div class="footer-intro">
      <div>
        <p class="footer-kicker">Start a conversation</p>
        <h2>Land worth returning to.</h2>
      </div>
      <div class="footer-actions">
        <a
          href={whatsappHref('Hello Elitas, I would like to know more about your projects.')}
          class="btn footer-primary"
          target="_blank"
          rel="noopener"
        >
          WhatsApp
        </a>
        <a href={SITE.phoneHref} class="btn footer-secondary">{SITE.phoneDisplay}</a>
      </div>
    </div>

    <div class="footer-rule"></div>

    <div class="footer-grid">
      <div>
        <a href={withBase('/')} class="footer-brand" aria-label="Elitas home">
          <ElitasMark size={30} />
          <span>Elitas</span>
        </a>
        <p class="footer-location">Hyderabad, Telangana</p>
      </div>

      <nav aria-label="Footer">
        <ul class="footer-links">
          <li><a href={withBase('/elite18')}>Elite 18</a></li>
          <li><a href={withBase('/anthara')}>Anthara</a></li>
          <li><a href={withBase('/design-system')}>Identity</a></li>
          <li><a href={withBase('/disclaimer')}>Disclaimer</a></li>
        </ul>
      </nav>
    </div>

    <p class="footer-legal">
      All imagery is an artistic impression. Farm house construction is optional and subject to
      G.O. 111 norms. Nothing on this site is an offer or approved-layout claim.
    </p>
    <p class="footer-copy">© {year} Elitas. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    padding-block: clamp(4rem, 10vw, 7rem) 2rem;
    background: #102822;
    color: #f2f4ef;
  }

  .footer-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 2rem;
  }

  .footer-kicker {
    margin-bottom: 0.75rem;
    color: #c8da72;
    font-size: 0.75rem;
    font-weight: 650;
  }

  .footer h2 {
    max-width: 11ch;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5.75rem);
    font-weight: 560;
    letter-spacing: -0.05em;
    line-height: 0.98;
  }

  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .footer-primary {
    background: #c8da72;
    border-color: #c8da72;
    color: #102822;
  }

  .footer-secondary {
    color: #f2f4ef;
    border-color: rgba(242, 244, 239, 0.5);
  }

  .footer-rule {
    height: 1px;
    margin-block: clamp(3rem, 7vw, 5rem) 2rem;
    background: rgba(242, 244, 239, 0.22);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    margin-bottom: 2.25rem;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .footer-brand :global(svg) {
    --mark-cut: #c8da72;
  }

  .footer-brand span {
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .footer-location,
  .footer-legal,
  .footer-copy {
    color: rgba(242, 244, 239, 0.66);
    font-size: 0.75rem;
  }

  .footer-location {
    margin-top: 0.75rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.75rem 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links a {
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: #c8da72;
  }

  .footer-legal {
    max-width: 65ch;
    line-height: 1.65;
  }

  .footer-copy {
    margin-top: 1.25rem;
  }

  @media (max-width: 720px) {
    .footer-intro,
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-actions,
    .footer-links {
      justify-content: flex-start;
    }

    .footer-actions {
      display: grid;
    }

    .footer-actions .btn {
      width: 100%;
    }

    .footer-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
