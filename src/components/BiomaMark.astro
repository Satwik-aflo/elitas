---
// The Bioma horizon mark (direction 1c): a laterite dome rising over an ink horizon.
interface Props {
  size?: number;
  dome?: string;
  line?: string;
  class?: string;
}
const { size = 24, dome = 'var(--laterite)', line = 'var(--ink)', class: className } = Astro.props;
const height = Math.round(size * (34 / 48));
---

<svg
  width={size}
  height={height}
  viewBox="0 0 48 34"
  fill="none"
  aria-hidden="true"
  class={className}
>
  <path d="M8 25 A16 16 0 0 1 40 25 Z" fill={dome}></path>
  <line x1="1" y1="30" x2="47" y2="30" stroke={line} stroke-width="2.6"></line>
</svg>
