---
// PROTOTYPE — DELETE AFTER A VARIANT WINS.
// Five animated treatments of the Bioma sun/horizon mark on the home hero,
// switchable via ?variant=A..E (floating bar, ← → keys). Throwaway code:
// no tests, minimal fallbacks; the winner gets rewritten properly.
const VARIANTS = [
  { key: 'A', name: 'Sunrise · scroll-linked' },
  { key: 'B', name: 'Ray wheel · slow rotation' },
  { key: 'C', name: 'Over the farmland' },
  { key: 'D', name: 'Growth rings' },
  { key: 'E', name: 'Day arc · rise to set' },
];
---

<div class="sunproto" data-sunproto>
  <!-- ============ A · SUNRISE ON SCROLL ============ -->
  <div class="sun-v" data-v="A" hidden>
    <svg viewBox="0 0 1200 110" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
      <defs>
        <clipPath id="clipA"><rect x="0" y="0" width="1200" height="100"></rect></clipPath>
      </defs>
      <g clip-path="url(#clipA)">
        <path class="a-dome" d="M520 92 A80 80 0 0 1 680 92 L680 200 L520 200 Z" fill="var(--laterite)"></path>
      </g>
      <line x1="0" y1="100" x2="1200" y2="100" stroke="var(--ink)" stroke-width="2.5"></line>
    </svg>
    <p class="sun-hint mono-data">SCROLL — THE SUN FOLLOWS</p>
  </div>

  <!-- ============ B · RAY WHEEL ============ -->
  <div class="sun-v" data-v="B" hidden>
    <svg viewBox="0 0 1200 150" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
      <defs>
        <clipPath id="clipB"><rect x="0" y="0" width="1200" height="140"></rect></clipPath>
      </defs>
      <g clip-path="url(#clipB)">
        <g class="b-rays">
          {
            Array.from({ length: 36 }, (_, i) => {
              const angle = (i * 360) / 36;
              const inner = 62;
              const outer = i % 3 === 0 ? 96 : i % 3 === 1 ? 82 : 74;
              return (
                <line
                  x1={600 + inner * Math.cos((angle * Math.PI) / 180)}
                  y1={140 + inner * Math.sin((angle * Math.PI) / 180)}
                  x2={600 + outer * Math.cos((angle * Math.PI) / 180)}
                  y2={140 + outer * Math.sin((angle * Math.PI) / 180)}
                  stroke="var(--laterite)"
                  stroke-width="1.6"
                  opacity="0.75"
                />
              );
            })
          }
        </g>
        <path d="M552 140 A48 48 0 0 1 648 140 Z" fill="var(--laterite)"></path>
      </g>
      <line x1="0" y1="140" x2="1200" y2="140" stroke="var(--ink)" stroke-width="2.5"></line>
    </svg>
  </div>

  <!-- ============ C · OVER THE FARMLAND ============ -->
  <div class="sun-v" data-v="C" hidden>
    <svg viewBox="0 0 1200 240" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
      <defs>
        <clipPath id="clipC"><rect x="0" y="0" width="1200" height="150"></rect></clipPath>
      </defs>
      <!-- sun + ticking rays above the horizon -->
      <g clip-path="url(#clipC)">
        <g class="c-rays">
          {
            Array.from({ length: 24 }, (_, i) => {
              const angle = (i * 360) / 24;
              return (
                <line
                  x1={600 + 70 * Math.cos((angle * Math.PI) / 180)}
                  y1={150 + 70 * Math.sin((angle * Math.PI) / 180)}
                  x2={600 + 84 * Math.cos((angle * Math.PI) / 180)}
                  y2={150 + 84 * Math.sin((angle * Math.PI) / 180)}
                  stroke="var(--laterite)"
                  stroke-width="1.8"
                  opacity="0.8"
                />
              );
            })
          }
        </g>
        <path class="c-sun" d="M545 150 A55 55 0 0 1 655 150 Z" fill="var(--laterite)"></path>
      </g>
      <line x1="0" y1="150" x2="1200" y2="150" stroke="var(--ink)" stroke-width="2.5"></line>
      <!-- furrows converging toward the sun -->
      <g stroke="var(--field)" stroke-width="1.3" opacity="0.55" fill="none">
        <path d="M600 152 L80 240"></path>
        <path d="M600 152 L280 240"></path>
        <path d="M600 152 L470 240"></path>
        <path d="M600 152 L730 240"></path>
        <path d="M600 152 L920 240"></path>
        <path d="M600 152 L1120 240"></path>
      </g>
      <!-- swaying jowar stalks along the field -->
      {
        [
          { x: 150, s: 1.0, d: 0 },
          { x: 300, s: 0.8, d: 0.7 },
          { x: 435, s: 1.1, d: 1.4 },
          { x: 760, s: 0.9, d: 0.4 },
          { x: 900, s: 1.15, d: 1.1 },
          { x: 1055, s: 0.85, d: 1.8 },
        ].map((t) => (
          <g
            class="c-stalk"
            style={`transform-origin:${t.x}px 238px; animation-delay:${t.d}s`}
            stroke="var(--field)"
            stroke-width="1.6"
            fill="none"
          >
            <path d={`M${t.x} 238 C${t.x - 2} ${238 - 26 * t.s} ${t.x + 2} ${238 - 34 * t.s} ${t.x} ${238 - 44 * t.s}`} />
            <path d={`M${t.x} ${238 - 20 * t.s} q-10 -7 -15 -17`} />
            <path d={`M${t.x} ${238 - 26 * t.s} q10 -6 14 -15`} />
            <circle cx={t.x} cy={238 - 47 * t.s} r={2.6 * t.s} fill="var(--field)" stroke="none" />
          </g>
        ))
      }
    </svg>
  </div>

  <!-- ============ D · GROWTH RINGS ============ -->
  <div class="sun-v" data-v="D" hidden>
    <svg viewBox="0 0 1200 170" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
      <defs>
        <clipPath id="clipD"><rect x="0" y="0" width="1200" height="160"></rect></clipPath>
      </defs>
      <g clip-path="url(#clipD)">
        <g fill="none" stroke="var(--laterite)">
          <circle class="d-ring" cx="600" cy="160" r="58" style="animation-delay:0s"></circle>
          <circle class="d-ring" cx="600" cy="160" r="58" style="animation-delay:1.5s"></circle>
          <circle class="d-ring" cx="600" cy="160" r="58" style="animation-delay:3s"></circle>
        </g>
        <path class="d-sun" d="M545 160 A55 55 0 0 1 655 160 Z" fill="var(--laterite)"></path>
      </g>
      <line x1="0" y1="160" x2="1200" y2="160" stroke="var(--ink)" stroke-width="2.5"></line>
    </svg>
  </div>

  <!-- ============ E · DAY ARC ============ -->
  <div class="sun-v" data-v="E" hidden>
    <svg viewBox="0 0 1200 210" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
      <defs>
        <clipPath id="clipE"><rect x="0" y="0" width="1200" height="200"></rect></clipPath>
      </defs>
      <path
        d="M180 200 Q600 -40 1020 200"
        fill="none"
        stroke="var(--ink)"
        stroke-width="1"
        stroke-dasharray="1 9"
        opacity="0.45"></path>
      <g clip-path="url(#clipE)">
        <circle r="30" fill="var(--laterite)">
          <animateMotion dur="16s" repeatCount="indefinite" keyPoints="0;1" keyTimes="0;1" calcMode="spline" keySplines="0.45 0 0.55 1" path="M180 214 Q600 -26 1020 214"></animateMotion>
        </circle>
      </g>
      <line x1="0" y1="200" x2="1200" y2="200" stroke="var(--ink)" stroke-width="2.5"></line>
    </svg>
  </div>

  <!-- ============ FLOATING SWITCHER ============ -->
  <div class="sun-bar" role="toolbar" aria-label="Prototype variant switcher">
    <button class="sun-bar-btn" data-prev aria-label="Previous variant">←</button>
    <span class="sun-bar-label" data-label>A — Sunrise · scroll-linked</span>
    <button class="sun-bar-btn" data-next aria-label="Next variant">→</button>
  </div>
</div>

<script define:vars={{ VARIANTS }}>
  const root = document.querySelector('[data-sunproto]');
  const blocks = [...root.querySelectorAll('.sun-v')];
  const label = root.querySelector('[data-label]');
  const keys = VARIANTS.map((v) => v.key);

  let current = new URLSearchParams(location.search).get('variant')?.toUpperCase();
  if (!keys.includes(current)) current = 'A';

  let scrollHandler = null;

  function applyScrollRise(active) {
    const dome = root.querySelector('.a-dome');
    if (scrollHandler) {
      removeEventListener('scroll', scrollHandler);
      scrollHandler = null;
    }
    if (!active || !dome) return;
    const update = () => {
      const range = innerHeight * 0.9;
      const p = Math.min(1, Math.max(0, scrollY / range));
      dome.style.transform = `translateY(${(1 - p) * 95}px)`;
    };
    scrollHandler = () => requestAnimationFrame(update);
    addEventListener('scroll', scrollHandler, { passive: true });
    update();
  }

  function show(key) {
    current = key;
    for (const b of blocks) b.hidden = b.dataset.v !== key;
    const v = VARIANTS.find((v) => v.key === key);
    label.textContent = `${v.key} — ${v.name}`;
    const url = new URL(location.href);
    url.searchParams.set('variant', key);
    history.replaceState(null, '', url);
    applyScrollRise(key === 'A');
  }

  function cycle(dir) {
    const i = (keys.indexOf(current) + dir + keys.length) % keys.length;
    show(keys[i]);
  }

  root.querySelector('[data-prev]').addEventListener('click', () => cycle(-1));
  root.querySelector('[data-next]').addEventListener('click', () => cycle(1));
  addEventListener('keydown', (e) => {
    const t = e.target;
    if (t instanceof HTMLElement && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
    if (e.key === 'ArrowLeft') cycle(-1);
    if (e.key === 'ArrowRight') cycle(1);
  });

  show(current);
</script>

<style>
  .sun-v svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .sun-hint {
    text-align: center;
    letter-spacing: 0.2em;
    font-size: 0.5rem;
    color: var(--stone);
    padding-block: 0.4rem;
  }

  /* A — dome moved by scroll JS */
  .a-dome {
    transform: translateY(95px);
    will-change: transform;
  }

  /* B — slow ray wheel */
  .b-rays {
    animation: sun-spin 80s linear infinite;
    transform-origin: 600px 140px;
  }

  /* C — farmland */
  .c-rays {
    animation: sun-spin 60s linear infinite;
    transform-origin: 600px 150px;
  }

  .c-stalk {
    animation: sun-sway 4.5s ease-in-out infinite alternate;
  }

  /* D — growth rings */
  .d-ring {
    stroke-width: 1.4;
    animation: sun-ring 4.5s cubic-bezier(0.2, 0.5, 0.6, 1) infinite;
  }

  @keyframes sun-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes sun-sway {
    from {
      transform: rotate(-2.4deg);
    }
    to {
      transform: rotate(2.4deg);
    }
  }

  @keyframes sun-ring {
    0% {
      transform: scale(1);
      opacity: 0.85;
    }
    100% {
      transform: scale(2.6);
      opacity: 0;
    }
  }

  .d-ring {
    transform-origin: 600px 160px;
  }

  @media (prefers-reduced-motion: reduce) {
    .b-rays,
    .c-rays,
    .c-stalk,
    .d-ring {
      animation: none;
    }

    .a-dome {
      transform: none !important;
    }
  }

  /* Switcher — deliberately not part of the design language */
  .sun-bar {
    position: fixed;
    bottom: 1.1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 90;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    background: #14100c;
    color: #fff;
    border-radius: 999px;
    padding: 0.55rem 1rem;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.35);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
  }

  .sun-bar-btn {
    background: none;
    border: 0;
    color: #fff;
    font-family: inherit;
    font-size: 0.8125rem;
    padding: 0.15rem 0.35rem;
  }

  .sun-bar-btn:hover {
    color: var(--terracotta);
  }

  .sun-bar-label {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
</style>
