---
import BiomaMark from './BiomaMark.astro';
import { withBase } from '../lib/site';

interface Props {
  /** 'paper' (default) or 'navy' (Anthara page) */
  theme?: 'paper' | 'navy';
}
const { theme = 'paper' } = Astro.props;
const links = [
  { label: 'Elite 18', href: withBase('/elite18') },
  { label: 'Anthara', href: withBase('/anthara') },
  { label: 'Contact', href: withBase('/#contact') },
];
const current = Astro.url.pathname.replace(/\/$/, '');
---

<header class:list={['nav', `nav--${theme}`]}>
  <div class="container nav-row">
    <a href={withBase('/')} class="nav-brand" aria-label="Bioma — home">
      <BiomaMark
        size={22}
        dome={theme === 'navy' ? 'var(--terracotta)' : 'var(--laterite)'}
        line={theme === 'navy' ? 'var(--paper)' : 'var(--ink)'}
      />
      <span class="nav-wordmark">Bioma</span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-links">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                aria-current={current === l.href.replace(/\/$/, '') ? 'page' : undefined}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: var(--hairline);
  }

  .nav--navy {
    background: color-mix(in srgb, var(--navy) 88%, transparent);
    border-bottom: 1px solid rgba(243, 237, 226, 0.25);
    color: var(--paper);
  }

  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.85rem;
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
  }

  .nav-wordmark {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    transform: translateY(0.05em);
  }

  .nav-links {
    display: flex;
    gap: clamp(0.9rem, 3.5vw, 1.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.15s ease;
    padding-block: 0.5rem;
  }

  .nav-links a:hover,
  .nav-links a[aria-current='page'] {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: var(--laterite);
  }

  .nav--navy .nav-links a[aria-current='page'],
  .nav--navy .nav-links a:hover {
    text-decoration-color: var(--terracotta);
  }
</style>
