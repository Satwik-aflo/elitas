---
import ElitasMark from './ElitasMark.astro';
import { withBase } from '../lib/site';

interface Props {
  theme?: 'paper' | 'navy';
}

const { theme = 'paper' } = Astro.props;
const links = [
  { label: 'Projects', href: withBase('/#projects') },
  { label: 'Partners', href: withBase('/#partners') },
  { label: 'Contact', href: withBase('/#contact') },
];
---

<header class:list={['nav', `nav--${theme}`]} data-nav>
  <div class="container nav-row">
    <a href={withBase('/')} class="nav-brand" aria-label="Elitas home">
      <ElitasMark size={28} />
      <span class="nav-wordmark">Elitas</span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Open navigation"
    >
      <span></span>
      <span></span>
    </button>

    <nav id="primary-nav" class="nav-menu" aria-label="Primary">
      <ul class="nav-links">
        {links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
      <a class="nav-project" href={withBase('/elite18')}>Explore Elite 18</a>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector('[data-nav]');
  const toggle = header?.querySelector('.nav-toggle');
  const menu = header?.querySelector('.nav-menu');

  const closeMenu = () => {
    header?.classList.remove('nav--open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open navigation');
  };

  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('nav--open') ?? false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
  });

  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 40;
    min-height: 70px;
    color: var(--forest);
    background: color-mix(in srgb, var(--canvas) 92%, transparent);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .nav--navy {
    color: var(--paper);
    background: color-mix(in srgb, var(--navy) 92%, transparent);
    border-color: rgba(242, 244, 239, 0.2);
  }

  .nav-row {
    min-height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    flex: none;
    color: inherit;
    text-decoration: none;
  }

  .nav-brand :global(svg) {
    --mark-cut: var(--accent);
  }

  .nav-wordmark {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .nav-menu,
  .nav-links {
    display: flex;
    align-items: center;
  }

  .nav-menu {
    gap: clamp(1.5rem, 4vw, 3.5rem);
  }

  .nav-links {
    gap: clamp(1rem, 2.5vw, 2rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a,
  .nav-project {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .nav-links a {
    padding-block: 1rem;
  }

  .nav-links a:hover {
    color: var(--accent-ink);
  }

  .nav-project {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    padding-inline: 1rem;
    background: var(--forest);
    color: var(--canvas);
    border: 1px solid var(--forest);
  }

  .nav--navy .nav-project {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--forest);
  }

  .nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid currentColor;
    background: transparent;
    color: inherit;
  }

  .nav-toggle span {
    display: block;
    width: 18px;
    height: 1px;
    margin: 5px auto;
    background: currentColor;
    transition: transform 180ms ease;
  }

  @media (max-width: 720px) {
    .nav-toggle {
      display: block;
    }

    .nav-menu {
      position: absolute;
      top: 70px;
      left: 0;
      right: 0;
      display: grid;
      gap: 1.25rem;
      padding: 1rem var(--gutter) 1.5rem;
      background: var(--canvas);
      border-bottom: 1px solid var(--line);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;
    }

    .nav--navy .nav-menu {
      background: var(--navy);
      border-color: rgba(242, 244, 239, 0.2);
    }

    .nav--open .nav-menu {
      opacity: 1;
      visibility: visible;
      transform: none;
    }

    .nav-links {
      display: grid;
      gap: 0;
    }

    .nav-links a {
      display: block;
      min-height: 48px;
      padding-block: 0.9rem;
      border-bottom: 1px solid var(--line);
    }

    .nav--navy .nav-links a {
      border-color: rgba(242, 244, 239, 0.2);
    }

    .nav-project {
      justify-content: center;
      min-height: 48px;
    }

    .nav--open .nav-toggle span:first-child {
      transform: translateY(3px) rotate(45deg);
    }

    .nav--open .nav-toggle span:last-child {
      transform: translateY(-3px) rotate(-45deg);
    }
  }
</style>
